generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum ClientStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum ServiceStatus {
  ACTIVE
  CANCELED
  UNKNOWN
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum MilestoneStatus {
  OPEN
  DONE
}

enum HandoverStatus {
  OPEN
  ACKED
}

enum AttachmentStatus {
  PENDING
  READY
}

enum ServiceType {
  DOMAIN
  HOSTING
  EMAIL
  CDN
  LICENSE
  MONITORING
  PAYMENT
  CMS
  OTHER
}

enum NotificationType {
  RENEWAL
  TASK
  INACTIVITY
  HANDOVER
}

enum NotificationStatus {
  OPEN
  SNOOZED
  HANDLED
}

enum InvoiceStatus {
  draft
  sent
  paid
  void
}

enum InvoiceTaxMode {
  uk_vat
  reverse_charge
  none
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  /// Issuer branding + bank details for invoices (JSON shape v1 — see invoiceIssuer Zod in app code).
  invoiceIssuer Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users       User[]
  clients     Client[]
  projects    Project[]
  milestones  Milestone[]
  tasks       Task[]
  taskDependencies TaskDependency[]
  notes       Note[]
  decisions   Decision[]
  handovers   Handover[]
  attachments Attachment[]
  attachmentLinks AttachmentLink[]
  notifications Notification[]
  activityLog ActivityLog[]
  invoices    Invoice[]
  invoiceSequences InvoiceSequence[]
  idempotencyRecords IdempotencyRecord[]
}

/// Request idempotency for safe retries (e.g. invoice email send). Stores only a safe response snapshot, not full bodies or attachments.
model IdempotencyRecord {
  id                 String   @id @default(uuid())
  workspaceId        String
  routeKey           String
  idempotencyKey     String
  requestFingerprint String
  /// Safe JSON: invoiceId, status, subject line flags, provider message id, idempotentReplay, etc. — not email HTML, not PDF, not full provider payload.
  responseSnapshot   Json
  createdAt          DateTime @default(now())
  expiresAt          DateTime?

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, routeKey, idempotencyKey])
  @@index([workspaceId, routeKey, createdAt])
  @@index([expiresAt])
}

model User {
  id           String   @id @default(uuid())
  workspaceId  String
  email        String   @unique
  name         String?
  role         Role     @default(MEMBER)
  passwordHash String?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Client {
  id          String       @id @default(uuid())
  workspaceId String
  name        String
  status      ClientStatus @default(ACTIVE)
  pinnedNotes String?
  tags        String[]     @default([])
  /// Default billing name for invoices (falls back to `name` when empty).
  billingRecipient String?
  billingEmail     String?
  billingAddress   String?
  billingVatId     String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  services      Service[]
  projects      Project[]
  tasks         Task[]
  assetLinks    AssetLink[]
  vaultPointers VaultPointer[]
  invoices      Invoice[]
}

model InvoiceSequence {
  id          String   @id @default(uuid())
  workspaceId String
  year        Int
  nextSequence Int     @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, year])
  @@index([workspaceId, year, updatedAt])
}

model Invoice {
  id               String        @id @default(uuid())
  workspaceId      String
  clientId         String
  invoiceNumber    String
  status           InvoiceStatus @default(draft)
  currency         String
  issueDate        DateTime
  dueDate          DateTime
  billingRecipient String?
  billingEmail     String?
  billingAddress   String?
  billingVatId     String?
  notes            String?
  paymentTerms     String?
  subtotalMinor    Int           @default(0)
  taxMinor         Int           @default(0)
  totalMinor       Int           @default(0)
  amountPaidMinor  Int           @default(0)
  sentAt           DateTime?
  paidAt           DateTime?
  voidedAt         DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lineItems InvoiceLineItem[]

  @@unique([workspaceId, invoiceNumber])
  @@index([workspaceId, status, dueDate])
  @@index([workspaceId, issueDate(sort: Desc)])
  @@index([workspaceId, clientId, issueDate(sort: Desc)])
}

model InvoiceLineItem {
  id               String         @id @default(uuid())
  invoiceId        String
  position         Int
  description      String
  quantity         Decimal        @db.Decimal(18, 4)
  unitPriceMinor   Int
  taxMode          InvoiceTaxMode @default(none)
  taxRateBps       Int            @default(0)
  lineSubtotalMinor Int
  lineTaxMinor     Int
  lineTotalMinor   Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, position])
  @@index([invoiceId, createdAt])
}

model Project {
  id          String        @id @default(uuid())
  workspaceId String
  clientId    String
  name        String
  keyPrefix   String
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  milestones Milestone[]
  tasks     Task[]

  @@index([workspaceId, status, updatedAt])
  @@index([clientId, updatedAt])
  @@unique([workspaceId, keyPrefix])
}

model Milestone {
  id          String          @id @default(uuid())
  workspaceId String
  projectId   String
  title       String
  dueAt       DateTime?
  status      MilestoneStatus @default(OPEN)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, dueAt])
  @@index([projectId, dueAt])
}

model Task {
  id          String     @id @default(uuid())
  workspaceId String
  clientId    String?
  projectId   String?
  title       String
  status      TaskStatus @default(TODO)
  dueAt       DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  project   Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  blockedBy  TaskDependency[] @relation("TaskBlockedBy")
  blocks     TaskDependency[] @relation("TaskBlocks")

  @@index([workspaceId, status, dueAt])
  @@index([clientId, dueAt])
  @@index([projectId, dueAt])
}

model TaskDependency {
  id            String   @id @default(uuid())
  workspaceId   String
  blockedTaskId String
  blockerTaskId String
  createdAt     DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  blockedTask Task      @relation("TaskBlockedBy", fields: [blockedTaskId], references: [id], onDelete: Cascade)
  blockerTask Task      @relation("TaskBlocks", fields: [blockerTaskId], references: [id], onDelete: Cascade)

  @@unique([blockedTaskId, blockerTaskId])
  @@index([workspaceId, createdAt])
  @@index([blockedTaskId])
  @@index([blockerTaskId])
}

model Note {
  id         String   @id @default(uuid())
  workspaceId String
  authorId   String
  entityType String
  entityId   String
  body       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, entityType, entityId, createdAt])
}

model Decision {
  id          String   @id @default(uuid())
  workspaceId String
  authorId    String
  entityType  String
  entityId    String
  title       String
  body        String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, entityType, entityId, createdAt])
}

model Handover {
  id          String         @id @default(uuid())
  workspaceId String
  fromUserId  String
  toUserId    String
  entityType  String
  entityId    String
  title       String
  body        String
  status      HandoverStatus @default(OPEN)
  ackedAt     DateTime?
  ackedById   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, entityType, entityId, createdAt])
}

model Attachment {
  id          String           @id @default(uuid())
  workspaceId String
  createdById String
  fileName    String
  mimeType    String
  sizeBytes   Int
  storageKey  String
  status      AttachmentStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  links     AttachmentLink[]

  @@index([workspaceId, createdAt])
  @@index([workspaceId, status, createdAt])
  @@index([workspaceId, storageKey])
}

model AttachmentLink {
  id           String   @id @default(uuid())
  workspaceId  String
  attachmentId String
  entityType   String
  entityId     String
  label        String?
  createdById  String
  createdAt    DateTime @default(now())

  workspace  Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@unique([attachmentId, entityType, entityId])
  @@index([workspaceId, entityType, entityId, createdAt])
  @@index([workspaceId, attachmentId])
}

model Service {
  id         String        @id @default(uuid())
  clientId   String
  provider   String
  type       ServiceType
  name       String
  status     ServiceStatus @default(ACTIVE)
  renewalDate DateTime?
  cycle      String?       // e.g. yearly, monthly
  costCents  Int?
  currency   String?       // EUR, GBP
  autoRenew  Boolean       @default(false)
  payer      String?       // client / us / shared
  reminderRules Json       @default("[]") // e.g. [60,30,14,7]
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model AssetLink {
  id        String   @id @default(uuid())
  clientId  String
  kind      String   // e.g. "hosting_panel", "repo", "wp_admin"
  label     String
  url       String
  environment String? // prod/stage
  tags      String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model VaultPointer {
  id          String   @id @default(uuid())
  clientId    String
  label       String
  vaultItemId String
  fieldName   String
  usernameHint String?
  ownerUserId String?
  lastVerifiedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         String   @id @default(uuid())
  workspaceId String
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json
  createdAt  DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
}

model Notification {
  id          String             @id @default(uuid())
  workspaceId String
  type        NotificationType
  status      NotificationStatus @default(OPEN)
  entityType  String
  entityId    String
  title       String
  message     String
  dueAt       DateTime
  snoozedUntil DateTime?
  handledAt   DateTime?
  handledById String?
  dedupeKey   String
  metadata    Json               @default("{}")
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, status, dueAt])
  @@index([workspaceId, type, dueAt])
  @@unique([workspaceId, dedupeKey])
}
