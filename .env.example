# App
APP_NAME="MTX Studio OS"
APP_URL="http://localhost:3000"
NODE_ENV="development"

# Auth
AUTH_COOKIE_NAME="mtxos_session"
AUTH_JWT_SECRET="replace_me_with_long_random"
AUTH_SESSION_DAYS="14"

# Seed (local first run)
SEED_OWNER_EMAIL="owner@mtxstudio.com"
SEED_OWNER_PASSWORD="ChangeMe123!"

# Database (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"

# Storage (optional placeholders for later phases)
STORAGE_ENDPOINT=""
STORAGE_REGION=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""
STORAGE_BUCKET=""
STORAGE_PUBLIC_BASE_URL=""

# Cron security (required in production, min 16 chars; use x-cron-secret or Bearer on cron routes)
CRON_SECRET="local-dev-cron-secret-min-16"

# Upstash Redis (rate limiting; optional in dev — falls back to in-memory)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Resend (invoice + auth emails; server-only)
RESEND_API_KEY=""
INVOICE_EMAIL_FROM=""
# Password reset from /login/forgot (falls back to INVOICE_EMAIL_FROM when unset)
AUTH_EMAIL_FROM=""

# Vaultwarden (Bitwarden compatible API)
VAULTWARDEN_URL="https://vault.example.com"
VAULTWARDEN_CLIENT_ID=""
VAULTWARDEN_CLIENT_SECRET=""
VAULTWARDEN_SCOPE="api"
